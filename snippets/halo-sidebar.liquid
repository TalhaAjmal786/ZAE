{%- comment -%}
  ZAE: settings.show_quick_cart was never written to settings_data.json. Its schema
  default is `true`, but an unsaved checkbox renders as an empty string, so the guard
  below was falsy and the cart sidebar markup never rendered at all.
  Fall back to the schema default so the sidebar exists unless quick cart is
  explicitly turned off.
{%- endcomment -%}

{%- liquid
    assign zae_show_quick_cart = true
    if settings.show_quick_cart == false
        assign zae_show_quick_cart = false
    endif

    assign zae_quick_cart_type = settings.quick_cart_type
    if zae_quick_cart_type == blank
        assign zae_quick_cart_type = 'sidebar'
    endif
-%}

{%- if settings.show_customer_login and settings.customer_login_type == 'sidebar' and shop.customer_accounts_enabled -%}
	{% render 'halo-customer-login-sidebar' %}
{%- endif -%}

{%- if zae_show_quick_cart and zae_quick_cart_type == 'sidebar' -%}
	{% render 'halo-cart-sidebar' %}
{%- endif -%}

{% render 'halo-sidebar-search' %}

{% render 'halo-sidebar-menu' %}

{%- if settings.show_before_you_leave -%}
	{% render 'halo-before-you-leave' %}
{%- endif -%}
