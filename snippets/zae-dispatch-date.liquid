{% comment %}
    ZAE: Estimated dispatch date box (standalone, no block needed).
    Rendered on product pages via snippets/zae-product-extras.liquid.
    Dates = today + min_days to today + max_days.
{% endcomment %}

{%- liquid
    assign min_days = 3
    assign max_days = 4
    assign label = 'Estimated dispatch dates'
    assign day_seconds = 86400
    assign start_ts = 'now' | date: '%s' | plus: 0
    assign from_ts = min_days | times: day_seconds | plus: start_ts
    assign to_ts = max_days | times: day_seconds | plus: start_ts
    assign from_date = from_ts | date: '%-d %b'
    assign to_date = to_ts | date: '%-d %b'
-%}

<div class="zae-dispatch">
    <div class="zae-dispatch__inner">
        <span class="zae-dispatch__icon" aria-hidden="true">
            <svg viewBox="0 0 640 512" width="22" height="22" fill="currentColor"><path d="M624 352h-16V243.9c0-12.7-5.1-24.9-14.1-33.9L494 110.1c-9-9-21.2-14.1-33.9-14.1H416V48c0-26.5-21.5-48-48-48H48C21.5 0 0 21.5 0 48v320c0 26.5 21.5 48 48 48h16c0 53 43 96 96 96s96-43 96-96h128c0 53 43 96 96 96s96-43 96-96h32c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16zM160 464c-26.5 0-48-21.5-48-48s21.5-48 48-48 48 21.5 48 48-21.5 48-48 48zm320 0c-26.5 0-48-21.5-48-48s21.5-48 48-48 48 21.5 48 48-21.5 48-48 48zm80-208H416V144h44.1l99.9 99.9V256z"></path></svg>
        </span>
        <span class="zae-dispatch__text">
            {{ label }} <strong>{{ from_date }} &ndash; {{ to_date }}</strong>
        </span>
    </div>
</div>
